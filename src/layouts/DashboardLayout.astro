---
import Layout from "../layouts/Layout.astro";

interface Props {
    title: string;
}

const { title } = Astro.props;

// Dashboard navigation items
const navItems = [
    { href: "/dashboard", text: "Ümumi Baxış", icon: "home" },
    { href: "/dashboard/profile", text: "Profil Parametrləri", icon: "user" },
    { href: "/dashboard/scripts", text: "Scriptlərim", icon: "code" },
];

// Get current path to highlight active nav item
const currentPath = Astro.url.pathname;
---

<Layout title={`${title} - Dashboard`}>
    <style>
        #dashboard {
            animation-duration: 400ms;
            transition: opacity 400ms ease;
        }
        #dashboard.is-changing {
            opacity: 0;
        }
        .nav-link {
            position: relative;
            transition: all 0.3s ease;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: #ea580c;
            transition: width 0.3s ease;
        }
        .nav-link:hover::after {
            width: 100%;
        }
        .nav-link.active {
            color: #ea580c;
            background: #fff1e6;
        }
        .nav-link.active::after {
            width: 100%;
        }
    </style>
    <div class="grid grid-cols-12 gap-6">
        <!-- Sidebar -->
        <aside class="col-span-12 md:col-span-3 lg:col-span-2">
            <nav class="bg-white rounded-lg shadow-md p-4">
                <ul class="space-y-2" id="sidebar">
                    {
                        navItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class:list={[
                                        "nav-link flex items-center space-x-2 px-4 py-2 rounded-md",
                                        currentPath === item.href
                                            ? "active"
                                            : "text-gray-600 hover:text-orange-600",
                                    ]}
                                >
                                    <span>{item.text}</span>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="col-span-12 md:col-span-9 lg:col-span-10">
            <div
                class="bg-white rounded-lg shadow-md p-6 dashboard"
                id="dashboard"
            >
                <slot />
            </div>
        </div>
    </div>
</Layout>