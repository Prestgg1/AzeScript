---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
}
const {title}=Astro.props 

---

<!doctype html>
<html lang="az">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-orange-50" >
		<Header />
		<main id="swup" class="container swup-transition-fade min-h-[80vh] mx-auto px-4 py-8">
			
			<slot />
		</main>
		<Footer />


    <!-- Swup.js Script -->
	<script>
		import('swup').then((SwupModule) => {
		  const Swup = SwupModule.default;
		  import('@swup/fade-theme').then((ThemeModule) => {
			const SwupFadeTheme = ThemeModule.default;
  
			// Swup'u başlat
			const swup = new Swup({
			  plugins: [new SwupFadeTheme()],
			});
		  });
		});
	  </script> 
	  </script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	html.is-animating .swup-transition-fade {
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.4s ease;
}

/* Geçiş tamamlandığında uygulanacak sınıf */
.swup-transition-fade {
  opacity: 1;
  transform: translateY(0);
  transition: all 0.4s ease;
}
</style>
