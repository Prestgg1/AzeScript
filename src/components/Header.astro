---
/* import HeaderDynamic from '../components/HeaderDynamic.vue'; */

import { isActive } from "../lib/isActive";
import AuthBtn from "./AuthBtn.astro";
import MobileMenu from "./MobileMenu.astro";
import { links } from "../lib/consts";
const pathname = Astro.originPathname;
---

<nav class="bg-white relative shadow-lg">
    <div class="container mx-auto px-4 mobile">
        <div class="flex justify-between items-center h-16">
            <!-- Logo/Site title -->
            <a href="/" class="text-2xl font-bold text-primary-600">AzeScript</a
            >
            <div class="hidden md:flex justify-center items-center space-x-8">
                <div
                    class="flex gap-3 justify-center items-center"
                    id="desktopNavigation"
                >
                    {
                        links.map((link) => (
                            <a
                                v-for="link in links"
                                href={link.href}
                                class:list={[
                                    "text-gray-600 cursor-pointer hover:text-primary-500 transition-colors",
                                    {
                                        activelink: isActive(
                                            pathname,
                                            link.href,
                                        ),
                                    },
                                ]}
                            >
                                {link.text}
                            </a>
                        ))
                    }
                </div>

                <!--   <HeaderDynamic client:only /> -->

                <AuthBtn />
            </div>
            <MobileMenu />
            <!-- Dinamik Header Bileşeni -->
        </div>
        <!-- Buraya Mobile Menu eklenicek -->
    </div>
</nav>
