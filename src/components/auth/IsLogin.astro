---
import { API_URL } from "../../lib/consts";
import axios from "axios";
type Auth_Token = {
    token: boolean;
};

if (Astro.cookies.has("User")) {
    axios(API_URL + "/users/user", {
        headers: {
            Authorization: `Bearer ${Astro.cookies.get("User")}`,
        },
    });
}
