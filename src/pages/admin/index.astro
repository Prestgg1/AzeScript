---
import AdminLayout from "../../layouts/AdminLayout.astro";

// Mock statistics
const stats = [
    { title: "Toplam Kullanıcı", value: "1,234", change: "+12%", icon: "users" },
    { title: "Toplam Script", value: "856", change: "+5%", icon: "code" },
    { title: "Aylık İndirme", value: "23K", change: "+18%", icon: "download" },
    { title: "Ortalama Puan", value: "4.8", change: "+2%", icon: "star" },
];

const recentActivities = [
    { user: "Ahmet K.", action: "yeni script ekledi", time: "5 dakika önce" },
    { user: "Mehmet Y.", action: "yorum yaptı", time: "15 dakika önce" },
    { user: "Ayşe S.", action: "script güncelledi", time: "1 saat önce" },
];
---

<AdminLayout title="Dashboard">
    <div class="space-y-6">
        <div class="flex justify-between items-center">
            <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
            <div class="flex space-x-3">
                <button class="bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 transition-colors">
                    Rapor Oluştur
                </button>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {
                stats.map((stat) => (
                    <div class="bg-white p-6 rounded-lg shadow-md">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="text-sm text-gray-600">{stat.title}</p>
                                <h3 class="text-2xl font-bold text-gray-800 mt-1">
                                    {stat.value}
                                </h3>
                            </div>
                            <span class="text-green-500 text-sm font-medium">
                                {stat.change}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- Recent Activity -->
        <div class="bg-white rounded-lg shadow-md p-6">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">
                Son Aktiviteler
            </h2>
            <div class="space-y-4">
                {
                    recentActivities.map((activity) => (
                        <div class="flex items-center justify-between border-b border-gray-100 pb-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
                                    <span class="text-orange-600 font-medium">
                                        {activity.user[0]}
                                    </span>
                                </div>
                                <div>
                                    <p class="text-sm text-gray-800">
                                        <span class="font-medium">
                                            {activity.user}
                                        </span>{" "}
                                        {activity.action}
                                    </p>
                                    <span class="text-xs text-gray-500">
                                        {activity.time}
                                    </span>
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</AdminLayout>
