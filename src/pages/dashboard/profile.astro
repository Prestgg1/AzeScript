---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ProfileForm from '../../components/dashboard/ProfileForm.vue';
import PasswordForm from '../../components/dashboard/PasswordForm.vue'; 
---
<DashboardLayout title="Profil Parametrləri" >
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Profil Parametrləri</h1>
  <!-- Profile Form -->
  <div  class="mb-8">
 <ProfileForm client:load />
  </div>
  <!-- Password Change -->
  <div class="border-t pt-6">
    <h2 class="text-lg font-semibold text-gray-800 mb-4">Şifrə Dəyiştir</h2>
    <PasswordForm client:load />
  </div>
</DashboardLayout>