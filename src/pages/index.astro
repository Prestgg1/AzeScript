---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AzeScript Market - Ana Səhifə">
  <section class="text-center py-12 bg-gradient-to-r from-primary-500 to-primary-600 rounded-lg mb-12">
    <h1 class="text-4xl font-bold text-white mb-4">
      Veb Layihələriniz Üçün Hazır Həllər
    </h1>
    <p class="text-primary-50 text-lg max-w-2xl mx-auto">
      Keyfiyyətli və etibarlı veb skriptləri ilə layihələrinizi sürətləndirin
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Seçilmiş Skriptlər</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
     
    </div>
  </section>

  <section class="bg-white rounded-lg p-8 shadow-md">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">Niyə Biz?</h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="text-primary-500 text-4xl mb-2">✨</div>
        <h3 class="font-semibold mb-2">Keyfiyyətli Kod</h3>
        <p class="text-gray-600">Müasir və təmiz kodlama standartları</p>
      </div>
      <div class="text-center">
        <div class="text-primary-500 text-4xl mb-2">🔒</div>
        <h3 class="font-semibold mb-2">Təhlükəsiz</h3>
        <p class="text-gray-600">Təhlükəsizlik boşluqlarına qarşı test edilmiş</p>
      </div>
      <div class="text-center">
        <div class="text-primary-500 text-4xl mb-2">💬</div>
        <h3 class="font-semibold mb-2">Dəstək</h3>
        <p class="text-gray-600">7/24 texniki dəstək</p>
      </div>
    </div>
  </section>
</Layout>
