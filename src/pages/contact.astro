---
import ContactForm from "../components/ContactForm.vue";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Əlaqə - AzeScript Market">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-800 mb-6">Əlaqə</h1>

        <div class="bg-white rounded-lg shadow-md p-8">
            <ContactForm client:load />

            <div class="mt-8 pt-8 border-t border-gray-200">
                <h2 class="text-xl font-semibold text-gray-800 mb-4">
                    Əlaqə Məlumatları
                </h2>
                <div class="space-y-2 text-gray-600">
                    <p>📧 E-poçt: info@webscriptmarket.com</p>
                    <p>📱 Telefon: +994 (55) 123 45 67</p>
                    <p>
                        📍 Ünvan: Texnologiya Məhəlləsi, Proqramlaşdırma Küçəsi
                        No:123
                    </p>
                </div>
            </div>
        </div>
    </div>
</Layout>
